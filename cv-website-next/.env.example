# Copy to .env and fill in your values.
# Set the same keys in Vercel → project → Settings → Environment Variables.

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Where contact-form messages are delivered.
# NOTE: until you verify a domain in Resend, this MUST be the email that owns
# your Resend account (test mode only delivers to the account owner).
MAIL_TO=your-resend-account-email@example.com

# Sender address. Leave as the Resend test sender until you verify your own
# domain at https://resend.com/domains (then use e.g. contact@yourdomain.com).
# MAIL_FROM=onboarding@resend.dev
